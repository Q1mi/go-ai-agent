# 火山方舟鉴权；也兼容变量名 DOUBAO_API_KEY
ARK_API_KEY=your-api-key

# 默认值沿用 demo 中原有的多模态 Embedding 模型
ARK_EMBEDDING_MODEL=doubao-embedding-vision-251215
ARK_EMBEDDING_API_TYPE=multimodal
EMBEDDING_DIMENSION=2048

# 可选配置
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# EMBEDDING_BATCH_SIZE=16
# MILVUS_ADDRESS=localhost:19530
# MILVUS_COLLECTION=eino_rag_demo
# MILVUS_VECTOR_FIELD=vector
# RAG_DOCS_DIR=../rag/docs
# RAG_CHUNK_SIZE=1200
# RAG_CHUNK_OVERLAP=150
