MINIKB_DSN=postgres://postgres:postgres@localhost:5432/minikb?sslmode=disable
MINIKB_EMBEDDER=local
MINIKB_EMBED_DIM=384

# Optional: use an OpenAI-compatible embedding endpoint.
# MINIKB_EMBEDDER=openai
# MINIKB_EMBED_BASE_URL=https://api.openai.com/v1
# MINIKB_EMBED_API_KEY=sk-your-api-key
# MINIKB_EMBED_MODEL=text-embedding-3-small
# MINIKB_EMBED_DIM=1536

# Optional: used by `ask --llm` and `agent`.
LLM_PROVIDER_NAME=openai-compatible
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-api-key
LLM_MODEL=deepseek-chat
